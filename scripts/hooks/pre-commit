#!/usr/bin/env bash
# Pre-commit hook for FlexLöve
# Install: bash scripts/install-hooks.sh

set -euo pipefail

REPO_ROOT=$(git rev-parse --show-toplevel)
cd "$REPO_ROOT"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BOLD='\033[1m'
NC='\033[0m'

pass() { echo -e "  ${GREEN}✓${NC} $1"; }
warn() { echo -e "  ${YELLOW}!${NC} $1"; }
fail() { echo -e "  ${RED}✗${NC} $1"; }

echo -e "${BOLD}FlexLöve pre-commit checks${NC}"
echo "─────────────────────────────"

ERRORS=0

# ── 1. Merge conflict markers ──────────────────────────────────────────────────
STAGED_ALL=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [ -n "$STAGED_ALL" ]; then
  CONFLICT_FILES=$(echo "$STAGED_ALL" | xargs grep -l "^<<<<<<< \|^>>>>>>> \|^=======$" 2>/dev/null || true)
  if [ -n "$CONFLICT_FILES" ]; then
    fail "Merge conflict markers found:"
    echo "$CONFLICT_FILES" | sed 's/^/      /'
    ERRORS=$((ERRORS + 1))
  else
    pass "No merge conflict markers"
  fi
fi

# ── 2. Lua formatting (stylua) ─────────────────────────────────────────────────
STAGED_LUA=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null | grep '\.lua$' || true)

if [ -n "$STAGED_LUA" ]; then
  if command -v stylua &>/dev/null; then
    UNFORMATTED=$(echo "$STAGED_LUA" | xargs stylua --check 2>&1 | grep "^Diff in" | sed 's/^Diff in //' | sed 's/:$//' || true)
    if [ -n "$UNFORMATTED" ]; then
      fail "Lua formatting issues (run: stylua <file> to fix):"
      echo "$UNFORMATTED" | sed 's/^/      /'
      ERRORS=$((ERRORS + 1))
    else
      pass "Lua formatting (stylua)"
    fi
  else
    warn "stylua not found — skipping format check (install: cargo install stylua)"
  fi
fi

# ── 3. Lua linting (luacheck) ──────────────────────────────────────────────────
if [ -n "$STAGED_LUA" ]; then
  if command -v luacheck &>/dev/null; then
    if ! echo "$STAGED_LUA" | xargs luacheck --config .luacheckrc 2>&1; then
      fail "Lua lint errors found"
      ERRORS=$((ERRORS + 1))
    else
      pass "Lua linting (luacheck)"
    fi
  else
    warn "luacheck not found — skipping lint (install: luarocks install luacheck)"
  fi
fi

# ── 4. Tests ───────────────────────────────────────────────────────────────────
if [ -n "$STAGED_LUA" ]; then
  echo "  Running tests..."
  if ! lua testing/runAll.lua --no-coverage 2>&1; then
    fail "Tests failed — fix before committing"
    ERRORS=$((ERRORS + 1))
  else
    pass "All tests passed"
  fi
fi

# ── Result ─────────────────────────────────────────────────────────────────────
echo "─────────────────────────────"
if [ "$ERRORS" -gt 0 ]; then
  echo -e "${RED}${BOLD}Commit blocked — $ERRORS check(s) failed${NC}"
  exit 1
fi
echo -e "${GREEN}${BOLD}All checks passed${NC}"
